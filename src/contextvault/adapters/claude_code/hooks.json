{
  "_comment": "ContextVault hooks for Claude Code. Installed by `contextvault adapter add claude-code` which merges these entries into ~/.claude/settings.json (never overwriting existing hooks).",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "contextvault hot --workspace \"$(contextvault workspaces ls --encode \"$PWD\" 2>/dev/null)\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "^/clear",
        "hooks": [
          {
            "type": "command",
            "command": "contextvault capture --cwd \"$PWD\" --mode final 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "contextvault capture --cwd \"$PWD\" --mode incremental 2>/dev/null &"
          }
        ]
      }
    ]
  }
}
